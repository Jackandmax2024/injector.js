  /* ═══════════════════════════════════════════════════════════════
     STATS + HISTORY
  ═══════════════════════════════════════════════════════════════ */
  const S = { correct: 0, wrong: 0, streak: 0, best: 0 };
  let hist = [], timings = [], qStart = Date.now();

  function startTimer() { qStart = Date.now(); }

  function record(ok, q, a) {
    const ms = Date.now() - qStart;
    if (ok) {
      S.correct++; S.streak++; timings.push(ms); if (timings.length > 20) timings.shift();
      if (S.streak > S.best) S.best = S.streak;
      confetti();
    } else { S.wrong++; S.streak = 0; }
    if (q) { hist.unshift({ q, a, ok, ms }); if (hist.length > 12) hist.pop(); }
    renderStats(); renderHistory(); previewSet('—'); startTimer();
  }

  function avgMs() {
    return timings.length ? Math.round(timings.reduce((a, b) => a + b) / timings.length) : 0;
  }

  function renderStats() {
    const el = document.getElementById('ch-stats'); if (!el) return;
    const tot = S.correct + S.wrong, acc = tot ? Math.round(S.correct / tot * 100) : 0, avg = avgMs();
    const sc = S.streak >= 10 ? '#e74c3c' : S.streak >= 5 ? '#f39c12' : '#2ecc71';
    el.innerHTML = `
      <div style="font-size:9px;color:#6b8fa3;text-align:center;font-weight:700;margin-bottom:5px;letter-spacing:.8px;">📊 STATS</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;text-align:center;">
        <div style="background:#eafff1;border-radius:6px;padding:5px;">
          <div style="font-size:20px;font-weight:700;color:${sc};">${S.streak}${S.streak>=5?'🔥':''}</div>
          <div style="font-size:9px;color:#6b8fa3;">STREAK</div>
        </div>
        <div style="background:#eafff1;border-radius:6px;padding:5px;">
          <div style="font-size:20px;font-weight:700;color:#2ecc71;">${acc}%</div>
          <div style="font-size:9px;color:#6b8fa3;">ACC</div>
        </div>
        <div style="background:#f0f7ff;border-radius:6px;padding:5px;">
          <div style="font-size:20px;font-weight:700;color:#3498db;">${S.correct}</div>
          <div style="font-size:9px;color:#6b8fa3;">CORRECT</div>
        </div>
        <div style="background:#fff0f0;border-radius:6px;padding:5px;">
          <div style="font-size:20px;font-weight:700;color:#e74c3c;">${S.wrong}</div>
          <div style="font-size:9px;color:#6b8fa3;">WRONG</div>
        </div>
      </div>
      <div style="display:flex;justify-content:space-between;margin-top:5px;font-size:9px;color:#8aabb0;padding:0 2px;">
        <span>🏆 Best: ${S.best}</span>
        <span>⚡ Avg: ${avg ? avg + 'ms' : '—'}</span>
      </div>`;
  }

  function renderHistory() {
    const el = document.getElementById('ch-hist'); if (!el || !hist.length) return;
    el.innerHTML = `
      <div style="font-size:9px;color:#6b8fa3;text-align:center;font-weight:700;margin-bottom:5px;letter-spacing:.8px;">📋 HISTORY</div>
      ${hist.slice(0, 7).map(h => `
        <div style="display:flex;justify-content:space-between;align-items:center;
          background:${h.ok?'#eafff1':'#fff0f0'};border-radius:5px;padding:3px 6px;margin-bottom:2px;font-size:10px;">
          <span style="color:#444;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:90px;"
            title="${h.q.replace(/"/g,'')}">${h.q.length > 12 ? h.q.slice(0, 12) + '…' : h.q}</span>
          <span style="font-weight:700;color:${h.ok?'#27ae60':'#e74c3c'};margin:0 4px;">${h.a}</span>
