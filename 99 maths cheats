/*
  99mths Enhanced Cheats UI — v3.1
  ─────────────────────────────────────────────────────────────────
  Hotkeys:
    Ctrl+Q  → toggle main overlay
    Ctrl+A  → auto answer (no panel open needed)
    Ctrl+D  → toggle debug panel

  Solvers:
    · Basic arithmetic  (+, -, ×, ÷, ^, sqrt, %)
    · Missing number    (_ + 5 = 12, 3 × _ = 15 …)
    · Comparison        (A __ B  →  > / < / =)
    · SVG fractions     (rectangle + pie)
    · Multiple choice   (numeric or text answer buttons)
    · Number line       (range inputs + custom sliders)
    · Word problems     (half of, quarter of, N% of …)
    · Mixed numbers     (1 3/4 → 7/4)
    · Decimals / negative numbers

  v3.1 Updates:
    · ENHANCED multi-format question detection (handles more game mode variants)
    · IMPROVED input detection (more reliable across different layouts)
    · Expanded Q_SELS with game-mode specific patterns
    · Better contenteditable support
    · More robust bestInput() fallbacks
*/

(function () {
  if (window.__cheats_ui_loaded) {
    console.log('[cheats] already loaded');
    return;
  }
  window.__cheats_ui_loaded = true;

  /* ═══════════════════════════════════════════════════════════════
     CONSTANTS
  ═══════════════════════════════════════════════════════════════ */
  const OVERLAY_ID  = 'cheats-ui-overlay-v3';
  const DEBUG_ID    = 'cheats-debug-panel-v3';
  const DARK_ID     = 'cheats-dark-style';
  const STAR_ID     = 'cheats-star-suppress';
  const STORE_KEY   = 'cheats_cfg_v3';

  let lastFilled = null;

  /* ═══════════════════════════════════════════════════════════════
     SETTINGS — persisted to localStorage
  ═══════════════════════════════════════════════════════════════ */
  const DEFAULTS = {
    confetti  : true,
    stars     : true,   // true = show, false = suppress
    darkMode  : false,
    autoSubmit: true,
    preview   : true,
  };

  let CFG = { ...DEFAULTS };

  function loadCfg() {
    try { Object.assign(CFG, JSON.parse(localStorage.getItem(STORE_KEY) || '{}')); } catch (e) {}
  }
  function saveCfg() {
    try { localStorage.setItem(STORE_KEY, JSON.stringify(CFG)); } catch (e) {}
  }
  loadCfg();

  /* ═══════════════════════════════════════════════════════════════
     CORE HELPERS
  ═══════════════════════════════════════════════════════════════ */
  function fire(el, ...events) {
    events.forEach(type => {
      try { el.dispatchEvent(new Event(type, { bubbles: true })); } catch (e) {}
    });
  }

  function isVis(el) {
    if (!el) return false;
    const s = window.getComputedStyle(el);
    if (s.display === 'none' || s.visibility === 'hidden' || parseFloat(s.opacity) === 0) return false;
    return !!(el.offsetWidth || el.offsetHeight || el.getClientRects().length);
  }

  function outsideUI(el) {
    return !el.closest('#' + OVERLAY_ID) && !el.closest('#' + DEBUG_ID);
  }

  function bestInput() {
    const f = document.activeElement;
    // Priority 1: Currently focused text input (if valid)
    if (f && f.tagName === 'INPUT' && !['button','submit','checkbox','radio'].includes(f.type) && outsideUI(f) && isVis(f))
      return f;
    
    // Priority 2: Focused contenteditable
    if (f && f.isContentEditable && outsideUI(f) && isVis(f)) return f;
    
    // Priority 3: First visible text input
    for (const i of document.querySelectorAll('input[type=text],input[type=number],input:not([type]),textarea')) {
      if (!outsideUI(i) || !isVis(i)) continue;
      const r = i.getBoundingClientRect();
      if (r.width > 20 && r.height > 10) return i;
    }
    
    // Priority 4: First visible contenteditable anywhere
    for (const ce of document.querySelectorAll('[contenteditable="true"]')) {
      if (outsideUI(ce) && isVis(ce)) return ce;
    }
    
    // Priority 5: Any visible form input (including hidden type)
    const inputs = [...document.querySelectorAll('input,textarea')].filter(i => outsideUI(i) && isVis(i));
    if (inputs.length) return inputs[0];
    
    return null;
  }

  const nativeSetter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set;

  function setVal(el, v) {
    if (el.tagName === 'INPUT') {
      nativeSetter.call(el, String(v));
    } else if (el.tagName === 'TEXTAREA') {
      el.textContent = String(v);
    }
    fire(el, 'input', 'change', 'blur');
  }

  function pressEnter(el) {
    ['keydown','keypress','keyup'].forEach(t =>
      el.dispatchEvent(new KeyboardEvent(t, { key: 'Enter', bubbles: true })));
    if (el.form) try { el.form.submit(); } catch (e) {}
  }

  function doFill(answer) {
    const t = bestInput();
    if (!t) { dbg('WARN', 'no input found'); return; }
    try { t.focus(); } catch (e) {}
    if (t.isContentEditable) {
      try { t.innerText = ''; fire(t, 'input', 'change'); } catch (e) {}
      try { t.innerText = String(answer); fire(t, 'input', 'change'); } catch (e) {}
    } else {
      setVal(t, ''); setVal(t, answer);
    }
    if (CFG.autoSubmit) pressEnter(t);
    lastFilled = t;
    previewSet(answer);
    dbg('FILL', `"${answer}" → ${t.tagName}[${t.type||'-'}]`);
  }

  const sleep = ms => new Promise(r => setTimeout(r, ms));

  /* ═══════════════════════════════════════════════════════════════
     QUESTION DETECTION — ENHANCED FOR MULTIPLE GAME MODES
  ═══════════════════════════════════════════════════════════════ */
  const Q_SELS = [
    // 99maths official selectors
    '.math99-game-question-view',
    '.math99-game-inGame-question-view',
    '[class*="math99"]',
    
    // Generic game selectors (updated)
    '[class*="question-view"]',
    '[class*="questionView"]',
    '[class*="inGame-question"]',
    '[class*="game-question"]',
    '[class*="question_view"]',
    '[class*="questionText"]',
    '[class*="question-text"]',
    '[class*="task-text"]',
    '[class*="problem-text"]',
    '[class*="task-container"]',
    '[class*="problem-container"]',
    '[class*="challenge"]',
    
    // Mobile-friendly variants
    '[class*="question-box"]',
    '[class*="question-card"]',
    '[class*="game-card"]',
    '[class*="item-content"]',
    
    // Alternative layouts
    '[data-question]',
    '[data-task]',
    '.question',
    '.task',
    '.challenge',
    '.math-problem',
    '.math-question',
  ];

  function detectQ() {
    // ─── TRY STANDARD SELECTORS ───
    for (const sel of Q_SELS) {
      const node = document.querySelector(sel);
      if (node) {
        const clone = node.cloneNode(true);
        clone.querySelectorAll('button,input,script,style,noscript,iframe').forEach(n => n.remove());
        const txt = (clone.textContent || '').replace(/\s+/g, ' ').trim();
        if (txt.length >= 2) { 
          dbg('Q', `[${sel}] "${txt.slice(0, 50)}"`);
          return txt;
        }
      }
    }

    // ─── HEURISTIC: LOOK FOR MATH-LIKE TEXT ───
    const isQL = t => t && /[0-9].*[-+×÷*\/=<>_?□]|[-+×÷*\/=<>_?□].*[0-9]|\?|what|calculate|solve|missing|find/i.test(t.replace(/\s+/g,' ').trim());
    
    // Search common container types with heuristic
    for (const sel of ['[class*=question]','[id*=question]','[class*=task]','[class*=prompt]','[class*=problem]','[class*=challenge]','main','[role=main]']) {
      const node = document.querySelector(sel);
      if (node && isQL(node.innerText) && outsideUI(node)) { 
        const txt = node.innerText.trim();
        dbg('Q', `[${sel}] "${txt.slice(0, 50)}"`);
        return txt;
      }
    }

    // ─── DEEP SCAN: ALL VISIBLE ELEMENTS ───
    for (const n of document.querySelectorAll('div,span,p,h1,h2,h3,h4,h5,li,label')) {
      const t = (n.innerText || n.textContent || '').trim();
      if (t.length > 2 && t.length < 300 && isQL(t) && isVis(n) && outsideUI(n)) {
        dbg('Q', `[generic] "${t.slice(0, 50)}"`);
        return t;
      }
    }

    return null;
  }

  /* ═══════════════════════════════════════════════════════════════
     SOLVERS
  ═══════════════════════════════════════════════════════════════ */

  /* ── missing-number  (_ + 5 = 12, 3 × _ = 15, _ / 4 = 3) ── */
  function solveMissing(text) {
    let s = text
      .replace(/×|\u00d7|\\times/g, '*').replace(/÷|\u00f7/g, '/')
      .replace(/\s+/g, '')
      .replace(/□|_+|missing|unknown/gi, '?');

    const configs = [
      // ? OP b = c
      { re: /^\?([+\-*\/])(-?[\d.]+)=(-?[\d.]+)$/, fn: (op,b,c) => {
        [b,c] = [+b,+c];
        if (op==='+') return c-b; if (op==='-') return c+b;
        if (op==='*') return b ? c/b : null; if (op==='/') return c*b;
      }},
      // a OP ? = c
      { re: /^(-?[\d.]+)([+\-*\/])\?=(-?[\d.]+)$/, fn: (a,op,c) => {
        [a,c] = [+a,+c];
        if (op==='+') return c-a; if (op==='-') return a-c;
        if (op==='*') return a ? c/a : null; if (op==='/') return a ? a*c : null;
      }},
    ];
    for (const { re, fn } of configs) {
      const m = s.match(re);
      if (m) {
        const v = fn(...m.slice(1));
        if (v !== null && isFinite(v)) {
          const r = Math.round(v);
          const ans = Math.abs(v - r) < 1e-9 ? String(r) : v.toFixed(4).replace(/\.?0+$/,'');
          dbg('SOLVER', `missing → ${ans}`);
          return ans;
        }
      }
    }
    return null;
  }

  /* ── comparison  (A __ B → >/</=) ── */
  function solveCompare(text) {
    const s = text.replace(/×|\u00d7/g,'*').replace(/÷|\u00f7/g,'/');
    const m = s.match(/([0-9+\-*\/\(\). ]+)\s*(?:__+|\?\?+|□)\s*([0-9+\-*\/\(\). ]+)/);
    if (!m) return null;
    try {
      const L = Function('"use strict";return(' + m[1] + ')')();
      const R = Function('"use strict";return(' + m[2] + ')')();
      if (!isFinite(L) || !isFinite(R)) return null;
      const r = L > R ? '>' : L < R ? '<' : '=';
      dbg('SOLVER', `compare → ${r}`);
      return r;
    } catch (e) { return null; }
  }

  /* ── main math solver ── */
  function solve(text) {
    if (!text) return null;

    // 1. missing number
    const miss = solveMissing(text);
    if (miss !== null) return miss;

    // 2. comparison
    const cmp = solveCompare(text);
    if (cmp !== null) return cmp;

    // 3. general eval
    let s = text.toLowerCase()
      .replace(/×|\u00d7/g,'*').replace(/÷|\u00f7/g,'/')
      .replace(/\btimes\b|\bmultiplied by\b/g,'*')
      .replace(/\bdivided by\b|\bover\b/g,'/')
      .replace(/\bplus\b/g,'+').replace(/\bminus\b/g,'-')
      .replace(/\bwhat is\b|\bwhat's\b|\bcalculate\b|\bsolve\b|\bfind\b/g,'')
      .replace(/negative\s*(\d)/g,'-$1')
      // percentages
      .replace(/(\d+(?:\.\d+)?)\s*%\s*of\s*(\d+(?:\.\d+)?)/g,'($1/100)*$2')
      .replace(/(\d+(?:\.\d+)?)\s*%/g,'($1/100)')
      // fractions-of
      .replace(/(\d+)\s*\/\s*(\d+)\s*of\s*(\d+)/g,'($1/$2)*$3')
      // mixed numbers  e.g. "1 3/4"
      .replace(/(\d+)\s+(\d+)\s*\/\s*(\d+)/g,'($1+$2/$3)')
      // word fractions
      .replace(/\bhalf of\s*(\d+)/g,'0.5*$1')
      .replace(/\bquarter of\s*(\d+)/g,'0.25*$1')
      .replace(/\bthird of\s*(\d+)/g,'(1/3)*$1')
      // powers
      .replace(/(\d+)\s*\^\s*(\d+)/g,'Math.pow($1,$2)')
      .replace(/(\d+)\s*squared/g,'Math.pow($1,2)')
      .replace(/(\d+)\s*cubed/g,'Math.pow($1,3)')
      .replace(/square root of\s*(\d+)/g,'Math.sqrt($1)')
      .replace(/sqrt\s*\(?\s*(\d+)\s*\)?/g,'Math.sqrt($1)')
      // implicit multiply  "3x5"
      .replace(/(\d)\s*x\s*(\d)/g,'$1*$2')
      .replace(/,/g,'')
      .replace(/[^0-9.\+\-\*\/\(\)\sMathpowsqrt]/g,' ')
      .replace(/\s+/g,' ').trim();

    if (!s) return null;
    try {
      const v = Function('"use strict";return(' + s + ')')();
      if (typeof v !== 'number' || !isFinite(v)) return String(v);
      const ri = Math.round(v);
      if (Math.abs(v - ri) < 1e-9) { dbg('SOLVER', `eval → ${ri}`); return String(ri); }
      // try to express as simple fraction
      for (let d = 2; d <= 16; d++) {
        const n = Math.round(v * d);
        if (Math.abs(n / d - v) < 1e-9) { dbg('SOLVER', `eval → ${n}/${d}`); return `${n}/${d}`; }
      }
      const r = v.toFixed(4).replace(/\.?0+$/,'');
      dbg('SOLVER', `eval → ${r}`);
      return r;
    } catch (e) { dbg('SOLVER', `eval fail: ${e.message}`); return null; }
  }

  /* ═══════════════════════════════════════════════════════════════
     SVG FRACTION DETECTION  (rectangle + pie + generic)
  ═══════════════════════════════════════════════════════════════ */
  function detectFrac() {
    // rectangle
    for (const sel of ['svg.rectangle-fraction','[class*="rectangle-fraction"] svg']) {
      const svg = document.querySelector(sel);
      if (svg) {
        const all = svg.querySelectorAll('rect'), col = [...all].filter(r => r.classList.contains('colored'));
        if (all.length) { dbg('FRAC', `rect ${col.length}/${all.length}`); return { n: col.length, d: all.length, type: 'rect' }; }
      }
    }
    // pie
    for (const sel of ['svg.pie-fraction','[class*="pie-fraction"] svg']) {
      const svg = document.querySelector(sel);
      if (svg) {
        const all = svg.querySelectorAll('path'), col = [...all].filter(p => p.classList.contains('colored'));
        if (all.length) { dbg('FRAC', `pie ${col.length}/${all.length}`); return { n: col.length, d: all.length, type: 'pie' }; }
      }
    }
    // generic: any SVG with .colored children
    for (const svg of document.querySelectorAll('svg')) {
      if (!outsideUI(svg)) continue;
      const shapes = svg.querySelectorAll('rect,path,circle,polygon');
      const col    = [...shapes].filter(e => e.classList.contains('colored'));
      if (shapes.length > 1 && col.length > 0 && col.length < shapes.length) {
        dbg('FRAC', `generic ${col.length}/${shapes.length}`);
        return { n: col.length, d: shapes.length, type: 'generic' };
      }
    }
    return null;
  }

  async function fillFrac(num, den) {
    const numEl = document.querySelector([
      'input.fraction__input--numerator',
      '[class*="fraction"][class*="numerator"] input',
      '[class*="numerator-input"]',
      '[class*="numerator"] input',
    ].join(','));
    const denEl = document.querySelector([
      'input.fraction__input--denominator',
      '[class*="fraction"][class*="denominator"] input',
      '[class*="denominator-input"]',
      '[class*="denominator"] input',
    ].join(','));
    if (!numEl || !denEl) { dbg('WARN', 'fraction inputs missing'); return; }

    function typeDigits(el, val) {
      setVal(el, ''); el.focus();
      String(val).split('').forEach(d => {
        const btn = [...document.querySelectorAll('.keyboard .buttons-row__button p,[class*="keypad"] button')]
          .find(p => (p.textContent || '').trim() === d);
        if (btn) (btn.parentElement || btn).click();
      });
      setVal(el, String(val));
    }
    typeDigits(numEl, num);
    await sleep(180);
    typeDigits(denEl, den);
    await sleep(180);
    const sub = document.querySelector([
      '.button__submit',
      '[class*="submit-btn"]',
      '[class*="submitBtn"]',
      '[class*="submit_button"]',
      '[class*="check-answer"]',
      'button[type=submit]',
    ].join(','));
    if (sub) sub.click();
    await sleep(120);
  }

  /* ═══════════════════════════════════════════════════════════════
     MULTIPLE CHOICE DETECTION
  ═══════════════════════════════════════════════════════════════ */
  const MC_SELS = [
    '[class*="answer-option"]','[class*="answerOption"]',
    '[class*="choice-btn"]','[class*="choiceBtn"]',
    '[class*="answer-btn"]','[class*="answerBtn"]',
    '[class*="mc-button"]','[class*="mcButton"]',
    '[class*="option-button"]','[class*="optionButton"]',
    '[class*="quiz-answer"]','[class*="quizAnswer"]',
    '[class*="answer-card"]','[class*="answerCard"]',
    '[class*="selection-btn"]','[class*="selectionBtn"]',
  ];

  function detectMC() {
    for (const sel of MC_SELS) {
      const btns = [...document.querySelectorAll(sel)].filter(b => outsideUI(b) && isVis(b));
      if (btns.length >= 2) { dbg('MC', `${btns.length} via ${sel}`); return btns; }
    }
    // fallback: visible buttons whose text is pure numbers or simple fractions
    const numBtns = [...document.querySelectorAll('button,[role=button]')]
      .filter(b => outsideUI(b) && isVis(b) && /^-?\d+(\.\d+)?(\/\d+)?$/.test((b.textContent||'').trim()));
    if (numBtns.length >= 2 && numBtns.length <= 6) { dbg('MC', `${numBtns.length} numeric fallback`); return numBtns; }
    return null;
  }

  function pickMCBtn(q, btns) {
    const ans = solve(q);
    if (ans === null) return null;
    const norm = s => s.replace(/\s+/g,'').toLowerCase();
    const ca   = norm(ans);
    const caNum = parseFloat(ans);
    for (const btn of btns) {
      const t = (btn.textContent || btn.innerText || '').trim();
      if (norm(t) === ca) return btn;
      if (isFinite(caNum) && Math.abs(parseFloat(t) - caNum) < 1e-9) return btn;
    }
    return null;
  }

  /* ═══════════════════════════════════════════════════════════════
     NUMBER LINE / RANGE INPUT
  ═══════════════════════════════════════════════════════════════ */
  function detectNL() {
    for (const sel of ['[class*="number-line"] input[type=range]','[class*="numberLine"] input[type=range]','input[type=range]','[class*="slider"] input']) {
      const el = document.querySelector(sel);
      if (el && outsideUI(el) && isVis(el)) { dbg('NL', sel); return el; }
    }
    return null;
  }

  function fillNL(el, ans) {
    const mn = parseFloat(el.min) || 0, mx = parseFloat(el.max) || 100;
    const v  = Math.max(mn, Math.min(mx, parseFloat(ans)));
    setVal(el, v);
    el.dispatchEvent(new MouseEvent('mouseup',{bubbles:true}));
    dbg('NL', `set ${v}`);
  }

  /* ═══════════════════════════════════════════════════════════════
     COMPARISON BUTTON DETECTION
  ═══════════════════════════════════════════════════════════════ */
  function detectCmpBtns() {
    const ops = ['>', '<', '=', '≤', '≥', '≠'];
    const found = [...document.querySelectorAll('button,[class*="operator"],[class*="symbol"]')]
      .filter(el => outsideUI(el) && isVis(el) && ops.includes((el.textContent||'').trim()));
    if (found.length) { dbg('CMP', found.map(b=>(b.textContent||'').trim()).join(' ')); return found; }
    return null;
  }

  /* ═══════════════════════════════════════════════════════════════
     TIMEOUT WRAPPER  (stuck-question fix)
  ═══════════════════════════════════════════════════════════════ */
  function withTimeout(fn, ms) {
    return new Promise(async res => {
      let done = false;
      const t = setTimeout(async () => {
        if (done) return; done = true;
        dbg('WARN', `timeout ${ms}ms — submitting wrong`);
        try { await wrongAnswer(); } catch (e) {}
        res();
      }, ms);
      try { await fn(); } catch (e) { dbg('ERR', e.message); }
      if (!done) { done = true; clearTimeout(t); res(); }
    });
  }

  /* ═══════════════════════════════════════════════════════════════
     CONFETTI
  ═══════════════════════════════════════════════════════════════ */
  function confetti() {
    if (!CFG.confetti) return;
    const cols = ['#2ecc71','#3498db','#f39c12','#e74c3c','#9b59b6','#1abc9c','#f1c40f'];
    for (let i = 0; i < 40; i++) {
      const el    = document.createElement('div');
      const size  = 6 + Math.random() * 8;
      const x     = Math.random() * window.innerWidth;
      const rot   = Math.random() * 360;
      const drift = (Math.random() - 0.5) * 200;
      const color = cols[Math.floor(Math.random() * cols.length)];
      el.className = '__cheats_confetti__';
      el.style.cssText = `position:fixed;left:${x}px;top:-20px;width:${size}px;height:${size}px;
        background:${color};border-radius:${Math.random()>.5?'50%':'2px'};
        z-index:2147483646;pointer-events:none;transform:rotate(${rot}deg);opacity:1;
        transition:transform 1.2s ease-out,top 1.2s ease-out,opacity 1.2s ease-out,left 1.2s ease-out;`;
      document.body.appendChild(el);
      requestAnimationFrame(() => requestAnimationFrame(() => {
        el.style.top    = (window.innerHeight * 0.3 + Math.random() * window.innerHeight * 0.5) + 'px';
        el.style.left   = (x + drift) + 'px';
        el.style.opacity = '0';
        el.style.transform = `rotate(${rot + 360}deg)`;
      }));
      setTimeout(() => el.remove(), 1400);
    }
  }

  /* ═══════════════════════════════════════════════════════════════
     STAR / REWARD SUPPRESSOR
  ═══════════════════════════════════════════════════════════════ */
  function applyStarSup() {
    let el = document.getElementById(STAR_ID);
    if (!el) { el = document.createElement('style'); el.id = STAR_ID; document.head.appendChild(el); }
    el.textContent = CFG.stars ? '' : `
      [class*="star"],[class*="Star"],[class*="reward"],[class*="Reward"],
      [class*="achievement"],[class*="Achievement"],[class*="badge"],[class*="Badge"],
      [class*="celebration"],[class*="Celebration"],[class*="confetti"],[class*="Confetti"],
      [class*="firework"],[class*="sparkle"],[class*="Sparkle"],[class*="trophy"],
      [class*="particle"],[class*="Particle"],[class*="burst"],[class*="Burst"],
      .__cheats_confetti__ {
        display:none!important;visibility:hidden!important;opacity:0!important;
        animation:none!important;transition:none!important;
      }`;
  }

  /* ═══════════════════════════════════════════════════════════════
     DARK MODE V2  — broad CSS-variable + class coverage
  ═══════════════════════════════════════════════════════════════ */
  function applyDark() {
    let el = document.getElementById(DARK_ID);
    if (!el) { el = document.createElement('style'); el.id = DARK_ID; document.head.appendChild(el); }
