// monkey_assistant_typable.js – Typable CPS up to 9999
(function() {
    'use strict';

    let autoTypeActive = false;
    let correctActive = false;
    let currentWord = '';
    let speed = 60;
    let ui = null;
    let uiVisible = true;
    let beforeInputHandler = null;
    let isAutoTyping = false;
    let isCorrecting = false;

    function getActiveWord() {
        const el = document.querySelector('.word.active');
        return el ? el.innerText.trim() : null;
    }

    function getInputElement() {
        return document.getElementById('wordsInput') || document.querySelector('[contenteditable="true"]');
    }

    function startAutoCorrect() {
        if (beforeInputHandler) stopAutoCorrect();
        const input = getInputElement();
        if (!input) {
            updateStatus('Error: input element not found');
            return;
        }
        beforeInputHandler = (e) => {
            if (!correctActive) return;
            if (isAutoTyping) return;
            if (isCorrecting) return;
            if (e.inputType !== 'insertText') return;
            if (!e.data || e.data.length !== 1) return;

            const targetWord = getActiveWord();
            if (!targetWord) return;

            const inputEl = getInputElement();
            if (!inputEl) return;

            let fullText = inputEl.innerText || '';
            fullText = fullText.replace(/\s+$/, '');
            let typedSoFar = fullText.split(' ').pop() || '';

            if (typedSoFar.length >= targetWord.length) return;

            const expectedChar = targetWord[typedSoFar.length];
            if (expectedChar && e.data !== expectedChar) {
                e.preventDefault();
                isCorrecting = true;
                document.execCommand('insertText', false, expectedChar);
                setTimeout(() => { isCorrecting = false; }, 20);
                updateStatus(`Corrected: "${e.data}" → "${expectedChar}"`);
            }
        };
        input.addEventListener('beforeinput', beforeInputHandler);
        updateStatus('Auto-correct ON');
    }

    function stopAutoCorrect() {
        const input = getInputElement();
        if (input && beforeInputHandler) {
            input.removeEventListener('beforeinput', beforeInputHandler);
            beforeInputHandler = null;
        }
        updateStatus('Auto-correct OFF');
    }

    function toggleCorrectMode() {
        correctActive = !correctActive;
        if (correctActive) {
            startAutoCorrect();
        } else {
            stopAutoCorrect();
        }
        const btn = document.getElementById('atToggleCorrect');
        if (btn) {
            btn.style.background = correctActive ? '#fa0' : '#444';
            btn.innerText = correctActive ? '✓ CORRECT ON' : '✗ CORRECT OFF';
        }
    }

    // ========== AUTO-TYPE ==========
    async function typeCharacter(char, target) {
        if (!target) return false;
        target.focus();
        isAutoTyping = true;
        document.execCommand('insertText', false, char);
        const delayMs = speed > 0 ? Math.max(0.5, 1000 / speed) : 0.5;
        await new Promise(r => setTimeout(r, delayMs));
        isAutoTyping = false;
        return true;
    }

    async function typeWord(word, inputEl) {
        for (let i = 0; i < word.length; i++) {
            if (!autoTypeActive) return false;
            await typeCharacter(word[i], inputEl);
        }
        isAutoTyping = true;
        document.execCommand('insertText', false, ' ');
        isAutoTyping = false;
        return true;
    }

    async function runAutoType() {
        if (!autoTypeActive) return;
        const word = getActiveWord();
        if (!word) {
            updateStatus('Waiting...');
            await new Promise(r => setTimeout(r, 500));
            if (!getActiveWord()) stopAutoType();
            else runAutoType();
            return;
        }
        if (word === currentWord) {
            await new Promise(r => setTimeout(r, 20));
            runAutoType();
            return;
        }
        currentWord = word;
        updateStatus(`Auto-typing: ${word} at ${speed} CPS`);
        const input = getInputElement();
        if (!input) { stopAutoType(); return; }
        await typeWord(word, input);
        if (autoTypeActive) setTimeout(runAutoType, 15);
    }

    function startAutoType() {
        if (autoTypeActive) return;
        autoTypeActive = true;
        currentWord = '';
        updateStatus('Auto-type started');
        runAutoType();
    }

    function stopAutoType() {
        autoTypeActive = false;
        updateStatus('Auto-type stopped');
    }

    // ========== CPS INPUT (type any number, up to 9999) ==========
    function applySpeed() {
        const input = document.getElementById('cpsTextInput');
        if (input) {
            let val = parseFloat(input.value);
            if (isNaN(val) || val < 0) val = 1;
            if (val > 9999) val = 9999;
            speed = val;
            document.getElementById('speedDisplay').innerText = speed;
            document.getElementById('atspeed').value = speed > 500 ? 500 : speed;
            updateStatus(`Speed set to ${speed} CPS`);
        }
    }

    function toggleUI() {
        if (!ui) return;
        uiVisible = !uiVisible;
        ui.style.display = uiVisible ? 'block' : 'none';
        updateStatus(uiVisible ? 'UI shown' : 'UI hidden');
    }

    // ========== UI ==========
    function createUI() {
        if (ui) ui.remove();
        ui = document.createElement('div');
        ui.id = 'autotype-ui';
        ui.style.cssText = `
            position: fixed; bottom: 20px; left: 20px; z-index: 99999;
            background: #1e1e1e; color: #0f0; font-family: monospace;
            padding: 14px 20px; border-radius: 14px; border: 1px solid #0f0;
            width: 340px; backdrop-filter: blur(4px); cursor: move;
            box-shadow: 0 0 25px rgba(0,255,0,0.15);
        `;
        ui.innerHTML = `
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                <b>⚡ MONKEY ASSIST</b>
                <span style="font-size:10px; color:#666;">Ctrl+Q toggle</span>
            </div>
            <div style="margin:8px 0; display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                <span style="font-size:13px;">CPS:</span>
                <input type="number" id="cpsTextInput" min="1" max="9999" value="${speed}" step="1" style="width:90px; padding:4px 8px; background:#222; border:1px solid #0f0; color:#0f0; border-radius:6px; font-family:monospace; font-size:14px;">
                <button id="applyCps" style="padding:4px 12px; background:#0f0; border:none; border-radius:6px; color:#000; font-weight:bold; cursor:pointer;">Apply</button>
                <span style="font-size:12px; color:#888;">or slider:</span>
                <input type="range" id="atspeed" min="1" max="500" value="${speed > 500 ? 500 : speed}" step="5" style="width:80px;">
                <span id="speedDisplay" style="font-size:14px; font-weight:bold; min-width:40px;">${speed}</span>
            </div>
            <div style="display:flex; gap:6px; margin:8px 0; flex-wrap:wrap;">
                <button id="atStart" style="flex:1; padding:6px 10px; background:#0f0; border:none; border-radius:8px; color:#000; font-weight:bold; cursor:pointer;">▶ AUTO-TYPE</button>
                <button id="atStop" style="flex:1; padding:6px 10px; background:#f00; border:none; border-radius:8px; color:#fff; font-weight:bold; cursor:pointer;">⏹ STOP</button>
                <button id="atToggleCorrect" style="flex:1; padding:6px 10px; background:#444; border:none; border-radius:8px; color:#fff; font-weight:bold; cursor:pointer;">✗ CORRECT OFF</button>
            </div>
            <div id="atStatus" style="font-size:12px; color:#888; text-align:center; margin-top:4px;">Status: IDLE</div>
            <div style="font-size:9px; color:#444; text-align:center; margin-top:4px;">Type any CPS (1–9999), then Apply or press Enter</div>
        `;
        document.body.appendChild(ui);

        document.getElementById('atStart').onclick = startAutoType;
        document.getElementById('atStop').onclick = stopAutoType;
        document.getElementById('atToggleCorrect').onclick = toggleCorrectMode;
        document.getElementById('applyCps').onclick = applySpeed;

        const slider = document.getElementById('atspeed');
        const cpsText = document.getElementById('cpsTextInput');
        const speedDisplay = document.getElementById('speedDisplay');

        // Slider changes speed
        slider.oninput = () => {
            const val = parseInt(slider.value);
            speed = val;
            cpsText.value = val;
            speedDisplay.innerText = val;
            updateStatus(`Speed set to ${val} CPS (slider)`);
        };

        // Typing in number box + Enter key
        cpsText.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                applySpeed();
            }
        });
        cpsText.addEventListener('change', applySpeed);

        // Also update speed display when typing manually
        cpsText.addEventListener('input', () => {
            let val = parseFloat(cpsText.value);
            if (!isNaN(val) && val >= 0) {
                speedDisplay.innerText = val > 9999 ? '9999' : val;
            }
        });

        // Draggable
        let offsetX, offsetY;
        ui.onmousedown = (e) => {
            if (e.target.closest('button') || e.target.closest('input')) return;
            offsetX = e.clientX - ui.offsetLeft;
            offsetY = e.clientY - ui.offsetTop;
            document.onmousemove = (m) => {
                ui.style.left = (m.clientX - offsetX) + 'px';
                ui.style.top = (m.clientY - offsetY) + 'px';
                ui.style.bottom = 'auto';
                ui.style.right = 'auto';
            };
            document.onmouseup = () => { document.onmousemove = null; };
        };
    }

    function updateStatus(msg) {
        const el = document.getElementById('atStatus');
        if (el) el.innerText = `Status: ${msg}`;
        console.log('[MonkeyAssist]', msg);
    }

    function init() {
        createUI();
        document.addEventListener('keydown', (e) => {
            if (e.ctrlKey && e.key === 'q') {
                e.preventDefault();
                toggleUI();
            }
        });
        updateStatus('Ready. Type CPS and press Enter or Apply.');
        if (window.location.hostname === 'monkeytype.com') {
            updateStatus('Monkeytype detected. Turn on CORRECT and type.');
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

    window.monkeyAssist = {
        startAutoType,
        stopAutoType,
        toggleCorrectMode,
        setSpeed: (cps) => { speed = Math.max(1, Math.min(9999, cps)); },
        toggleUI
    };
})();
