      else if (i===6) {
        const inp=[...document.querySelectorAll('input,textarea')].filter(outsideUI);
        dbg('DOM',`Inputs (${inp.length}):`);
        inp.slice(0,10).forEach((e,j)=>dbg('DOM',`  [${j}] ${e.tagName} type=${e.type||'-'} cls="${e.className.slice(0,28)}" val="${(e.value||'').slice(0,18)}"`));
      }
      else if (i===7) {
        const svgs=[...document.querySelectorAll('svg')].filter(outsideUI);
        dbg('DOM',`SVGs (${svgs.length}):`);
        svgs.slice(0,8).forEach((e,j)=>{
          const r=e.querySelectorAll('rect').length,pt=e.querySelectorAll('path').length,c=e.querySelectorAll('.colored').length;
          dbg('DOM',`  [${j}] cls="${e.className.slice?e.className.slice(0,22):''}" r=${r} p=${pt} col=${c}`);
        });
      }
      else if (i===8) {
        const btns=[...document.querySelectorAll('button')].filter(outsideUI).filter(isVis);
        dbg('DOM',`Buttons (${btns.length}):`);
        btns.slice(0,12).forEach((b,j)=>dbg('DOM',`  [${j}] "${(b.textContent||'').trim().slice(0,30)}" cls="${b.className.slice(0,24)}"`));
      }
    }));

    renderLog(p.querySelector('#dbg-log'));
    updateDbgState();
  }

  const DBG_BTN = `background:#1c2128;border:1px solid #30363d;border-radius:4px;padding:3px 6px;cursor:pointer;font-size:10px;font-family:monospace;`;

  function toggleDebug() {
    const el = document.getElementById(DEBUG_ID);
    if (el) el.remove(); else createDebugPanel();
  }

  /* ═══════════════════════════════════════════════════════════════
     MAIN OVERLAY
  ═══════════════════════════════════════════════════════════════ */
  function mkBtn(id, label, grad, shadow, extra = '') {
    return `<button id="${id}" style="padding:8px 0;background:${grad};color:#fff;border:0;
      border-radius:8px;cursor:pointer;font-size:12px;font-weight:600;
      box-shadow:0 3px 8px ${shadow};transition:opacity .15s;${extra}">${label}</button>`;
  }
  const G  = (id,lbl,x='') => mkBtn(id,lbl,'linear-gradient(90deg,#7bd389,#2ecc71)','rgba(46,204,113,.25)',x);
  const R  = (id,lbl,x='') => mkBtn(id,lbl,'linear-gradient(90deg,#ff6b6b,#e03131)','rgba(224,49,49,.25)',x);
  const V  = (id,lbl,x='') => mkBtn(id,lbl,'linear-gradient(90deg,#a29bfe,#6c5ce7)','rgba(108,92,231,.25)',x);
  const GY = (id,lbl,x='') => mkBtn(id,lbl,'linear-gradient(90deg,#606472,#3a3d4d)','rgba(0,0,0,.2)',x);
  const IN = (id,ph,w='100%') => `<input id="${id}" type="number" min="1" placeholder="${ph}"
    style="width:${w};padding:7px 5px;border:1px solid #d0e8ff;border-radius:7px;font-size:11px;
      text-align:center;background:#f7fbff;color:#102A43;outline:none;box-sizing:border-box;"/>`;

  const SECTION = (title, body) =>
    `<div style="background:#f7fbff;border-radius:9px;padding:8px;border:1px solid #d0e8ff;">
      <div style="font-size:9px;color:#6b8fa3;font-weight:700;letter-spacing:.6px;margin-bottom:6px;">${title}</div>
      ${body}
    </div>`;

  function createOverlay() {
    if (document.getElementById(OVERLAY_ID)) return;
    const p = document.createElement('div');
    p.id = OVERLAY_ID;
    p.style.cssText = `position:fixed;right:12px;top:60px;z-index:2147483647;
      display:flex;flex-direction:column;gap:6px;align-items:stretch;
      font-family:Inter,system-ui,sans-serif;width:192px;
      max-height:90vh;overflow-y:auto;`;

    p.innerHTML = `
      <!-- HEADER -->
      <div style="background:linear-gradient(90deg,#667eea,#764ba2);border-radius:12px;padding:12px;color:#fff;text-align:center;">
        <div style="font-size:13px;font-weight:700;">✨ 99 MATHS</div>
        <div style="font-size:9px;color:#e0d7ff;margin-top:2px;">v3.1 Enhanced</div>
      </div>

      <!-- MAIN ACTION -->
      ${G('ch-auto','🎯 AUTO ANSWER','width:100%;')}

      <!-- TOOLS -->
      ${SECTION('TOOLS',`
        ${G('ch-fracs','📊 Fill Fraction','margin-bottom:5px;width:100%;')}
        ${R('ch-wrong','❌ Wrong Answer','width:100%;')}
      `)}

      <!-- SPAM / RESET -->
      ${SECTION('BATCH','
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-bottom:5px;">
          ${IN('ch-spam-count','Count','')}
          ${IN('ch-spam-ms','ms','')}
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;">
          ${G('ch-spam-start','▶ Spam','')}
          ${R('ch-spam-stop','⏹ Stop','')}
        </div>
        <div id="ch-spam-status" style="text-align:center;margin-top:4px;font-size:10px;color:#8aabb0;">⚫ Idle</div>
        <div id="ch-spam-prog" style="text-align:center;font-size:10px;color:#6b8fa3;"></div>
      ')}

      ${SECTION('RESET MODE','
        ${IN('ch-interval','Interval (ms)','')}
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-top:5px;">
          ${V('ch-reset-start','⚙ Start','')}
          ${R('ch-reset-stop','⏹ Stop','')}
        </div>
        <div id="ch-reset-status" style="text-align:center;margin-top:4px;font-size:10px;color:#8aabb0;">⚫ Idle</div>
      ')}

      <!-- SETTINGS -->
      ${SECTION('SETTINGS','
        ${tog({label:'🎆 Confetti',span:'ch-tog-confetti'},CFG.confetti)}
        <div style="height:6px;"></div>
        ${tog({label:'⭐ Show Stars',span:'ch-tog-stars'},CFG.stars)}
        <div style="height:6px;"></div>
        ${tog({label:'🌙 Dark Mode',span:'ch-tog-dark'},CFG.darkMode)}
        <div style="height:6px;"></div>
        ${tog({label:'⚡ Auto Submit',span:'ch-tog-submit'},CFG.autoSubmit)}
      ')}

      <!-- INFO -->
      ${SECTION('PREVIEW','
        <div style="background:#fff;border-radius:6px;padding:6px;font-size:11px;color:#2d3748;text-align:center;font-weight:700;min-height:20px;" id="ch-preview">—</div>
      ')}

      ${SECTION('STATS','
        <div id="ch-stats"></div>
      ')}

      ${SECTION('HISTORY','
        <div id="ch-hist"></div>
      ')}

      <!-- DEBUG -->
      ${GY('ch-debug','🐛 Debug Panel','width:100%;')}
    `;

    document.body.appendChild(p);

    // BINDINGS
    document.getElementById('ch-auto').addEventListener('click', () => autoAnswer());
    document.getElementById('ch-wrong').addEventListener('click', () => wrongAnswer());
    document.getElementById('ch-fracs').addEventListener('click', async () => {
      const f = detectFrac();
      if (f) await fillFrac(f.n, f.d);
      else dbg('WARN', 'no fraction detected');
    });
    document.getElementById('ch-spam-start').addEventListener('click', () => spamAuto(document.getElementById('ch-spam-count').value, document.getElementById('ch-spam-ms').value));
    document.getElementById('ch-spam-stop').addEventListener('click', () => stopSpam());
    document.getElementById('ch-reset-start').addEventListener('click', () => startReset(parseInt(document.getElementById('ch-interval').value, 10)));
    document.getElementById('ch-reset-stop').addEventListener('click', () => stopReset());
    document.getElementById('ch-debug').addEventListener('click', () => toggleDebug());

    bindToggle('ch-tog-confetti', (on) => { CFG.confetti = on; saveCfg(); applyDark(); });
    bindToggle('ch-tog-stars', (on) => { CFG.stars = on; saveCfg(); applyStarSup(); });
    bindToggle('ch-tog-dark', (on) => { CFG.darkMode = on; saveCfg(); applyDark(); });
    bindToggle('ch-tog-submit', (on) => { CFG.autoSubmit = on; saveCfg(); });

    applyDark();
    applyStarSup();
    renderStats();
    renderHistory();
  }

  function toggleOverlay() {
    const el = document.getElementById(OVERLAY_ID);
    if (el) el.remove();
    else createOverlay();
  }

  /* ═══════════════════════════════════════════════════════════════
     HOTKEYS
  ═══════════════════════════════════════════════════════════════ */
  document.addEventListener('keydown', (e) => {
    if (e.ctrlKey && e.key === 'q') { e.preventDefault(); toggleOverlay(); }
    if (e.ctrlKey && e.key === 'a') { e.preventDefault(); autoAnswer(); }
    if (e.ctrlKey && e.key === 'd') { e.preventDefault(); toggleDebug(); }
  });

  // ─── INIT ───
  dbg('INFO', 'v3.1 loaded. Press Ctrl+Q for overlay');
  previewSet('—');
})();
