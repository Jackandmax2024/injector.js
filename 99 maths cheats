  function previewSet(v) {
    const el = document.getElementById('ch-preview');
    if (el) el.textContent = v;
  }

  /* ═══════════════════════════════════════════════════════════════
     AUTO ANSWER  (unified — tries all detectors in order)
  ═══════════════════════════════════════════════════════════════ */
  async function autoAnswer() {
    startTimer();
    dbg('AUTO', 'running…');

    // 1. SVG fraction
    const frac = detectFrac();
    if (frac) {
      const lbl = `${frac.n}/${frac.d}`;
      dbg('AUTO', `fraction ${lbl}`);
      previewSet(lbl); record(true, 'fraction', lbl);
      await fillFrac(frac.n, frac.d);
      return;
    }

    const q = detectQ();

    // 2. Multiple choice
    const mc = detectMC();
    if (mc && q) {
      const btn = pickMCBtn(q, mc);
      if (btn) {
        const a = (btn.textContent || btn.innerText || '').trim();
        dbg('AUTO', `MC → ${a}`); previewSet(a); record(true, q, a);
        btn.click(); return;
      }
    }

    // 3. Comparison buttons
    if (q) {
      const cmpResult = solveCompare(q);
      if (cmpResult) {
        const cmpBtns = detectCmpBtns();
        if (cmpBtns) {
          const btn = cmpBtns.find(b => (b.textContent || '').trim() === cmpResult);
          if (btn) { dbg('AUTO', `cmp btn → ${cmpResult}`); previewSet(cmpResult); record(true, q, cmpResult); btn.click(); return; }
        }
        // fall through to text fill
        dbg('AUTO', `cmp fill → ${cmpResult}`); previewSet(cmpResult); record(true, q, cmpResult);
        doFill(cmpResult); return;
      }

      // 4. Number line
      const nl = detectNL();
      if (nl) {
        const ans = solve(q);
        if (ans !== null) {
          dbg('AUTO', `NL → ${ans}`); previewSet(ans); record(true, q, ans);
          fillNL(nl, ans); return;
        }
      }

      // 5. Standard text fill
      const ans = solve(q);
      if (ans === null) { dbg('WARN', `unsolvable: "${q}"`); return; }
      dbg('AUTO', `fill → ${ans}`); previewSet(ans); record(true, q, ans);
      doFill(ans);
    } else {
      dbg('WARN', 'no question detected');
    }
  }

  async function wrongAnswer() {
    const frac = detectFrac();
    if (frac) {
      const w = frac.n >= frac.d ? frac.n - 1 : frac.n + 1;
      record(false, 'fraction', `${w}/${frac.d}`);
      await fillFrac(w, frac.d); return;
    }
    const q   = detectQ();
    const ans = q ? solve(q) : null;
    const w   = ans !== null ? String(parseInt(ans, 10) + 1) : '99999';
    record(false, q || '?', w);
    doFill(w);
    dbg('WRONG', w);
  }

  /* ═══════════════════════════════════════════════════════════════
     SPAM
  ═══════════════════════════════════════════════════════════════ */
  let spamRunning = false;

  async function spamAuto(n, ms) {
    if (spamRunning) return;
    const count = parseInt(n, 10) || 10;
    const delay = (parseInt(ms, 10) > 0 ? parseInt(ms, 10) : 500);
    spamRunning = true;
    badge('ch-spam-status', true);
    for (let i = 0; i < count; i++) {
      if (!spamRunning) break;
      spamProg(i + 1, count);
      await withTimeout(() => autoAnswer(), delay + 600);
      if (i < count - 1) await sleep(delay);
    }
    spamRunning = false;
    badge('ch-spam-status', false);
    spamProg(0, 0);
    dbg('SPAM', 'done');
  }
  function stopSpam() { spamRunning = false; badge('ch-spam-status', false); }
  function spamProg(cur, tot) {
    const el = document.getElementById('ch-spam-prog');
    if (el) el.textContent = (cur && tot) ? `${cur}/${tot}` : '';
  }

  /* ═══════════════════════════════════════════════════════════════
     RESET SCORE
  ═══════════════════════════════════════════════════════════════ */
  let resetRunning = false;

  async function startReset(ms) {
    if (resetRunning) return;
    resetRunning = true;
    badge('ch-reset-status', true, '#e74c3c');
    dbg('RESET', 'started');
    const getD = () => {
      const v = parseFloat((document.getElementById('ch-interval') || {}).value);
      return isFinite(v) && v > 0 ? Math.round(v) : (ms || 800);
    };
    while (resetRunning) {
      try {
        const d = getD();
        await withTimeout(() => wrongAnswer(), d + 600);  await sleep(d); if (!resetRunning) break;
        await withTimeout(() => wrongAnswer(), d + 600);  await sleep(d); if (!resetRunning) break;
        await withTimeout(() => autoAnswer(), d + 600);   await sleep(d);
      } catch (e) { dbg('ERR', e.message); resetRunning = false; }
    }
    resetRunning = false;
    badge('ch-reset-status', false);
    dbg('RESET', 'stopped');
  }
  function stopReset() { resetRunning = false; badge('ch-reset-status', false); }

  /* ═══════════════════════════════════════════════════════════════
     UI HELPERS
  ═══════════════════════════════════════════════════════════════ */
  function badge(id, on, color = '#2ecc71') {
    const el = document.getElementById(id); if (!el) return;
    el.textContent = on ? '🟢 Running' : '⚫ Idle';
    el.style.color  = on ? color : '#8aabb0';
  }

  function tog(id, checked) {
    return `<label style="display:flex;justify-content:space-between;align-items:center;
      background:#f0f7ff;border-radius:7px;padding:5px 9px;cursor:pointer;border:1px solid #d0e8ff;">
      <span style="font-size:11px;color:#2d3748;font-weight:500;">${id.label}</span>
      <span style="display:inline-block;width:32px;height:17px;background:${checked?'#2ecc71':'#cbd5e0'};
        border-radius:9px;position:relative;cursor:pointer;transition:background .2s;"
        id="${id.span}" data-on="${checked?1:0}">
        <span style="position:absolute;top:2px;left:${checked?'15px':'2px'};width:13px;height:13px;
          background:#fff;border-radius:50%;transition:left .2s;box-shadow:0 1px 3px rgba(0,0,0,.3);"></span>
      </span></label>`;
  }

  function bindToggle(spanId, onFn) {
    const el = document.getElementById(spanId); if (!el) return;
    el.addEventListener('click', function () {
      const on = this.dataset.on === '0';
      this.dataset.on = on ? '1' : '0';
      this.style.background = on ? '#2ecc71' : '#cbd5e0';
      this.querySelector('span').style.left = on ? '15px' : '2px';
      onFn(on);
    });
  }

  /* ═══════════════════════════════════════════════════════════════
     DEBUG PANEL
  ═══════════════════════════════════════════════════════════════ */
  let logs = [];

  function dbg(type, msg) {
    const entry = {
      type, msg: String(msg),
      t: new Date().toLocaleTimeString('en',{hour12:false,hour:'2-digit',minute:'2-digit',second:'2-digit',fractionalSecondDigits:1})
    };
    logs.unshift(entry); if (logs.length > 100) logs.pop();
    const el = document.getElementById('dbg-log'); if (el) renderLog(el);
    console.log(`[cheats:${type}]`, msg);
  }

  const TYPE_COL = {
    AUTO:'#2ecc71',SOLVER:'#3498db',FRAC:'#9b59b6',Q:'#f39c12',
    MC:'#1abc9c',NL:'#e67e22',SPAM:'#3498db',RESET:'#e74c3c',
    WRONG:'#e74c3c',WARN:'#f39c12',ERR:'#ff6b6b',INFO:'#8b949e',
    FILL:'#58a6ff',CMP:'#27ae60',DOM:'#40b5a4',
  };

  function renderLog(el) {
    el.innerHTML = logs.slice(0, 50).map(e => `
      <div style="display:flex;gap:5px;margin-bottom:2px;font-size:10px;border-bottom:1px solid #1a2030;padding-bottom:2px;">
        <span style="color:#374151;min-width:55px;flex-shrink:0;">${e.t}</span>
        <span style="color:${TYPE_COL[e.type]||'#a0aec0'};font-weight:700;min-width:52px;flex-shrink:0;">${e.type}</span>
        <span style="color:#c9d1d9;word-break:break-all;">${e.msg}</span>
      </div>`).join('');
  }

  function debugScan() {
    dbg('DOM', '── SCAN START ──');
    const q   = detectQ();    dbg('DOM', `Q: ${q ? '"' + q + '"' : 'none'}`);
    const f   = detectFrac(); dbg('DOM', `Frac: ${f ? f.n+'/'+f.d+'('+f.type+')' : 'none'}`);
    const mc  = detectMC();   dbg('DOM', `MC: ${mc ? mc.length + ' btns [' + mc.map(b=>(b.textContent||'').trim().slice(0,6)).join(',') + ']' : 'none'}`);
    const nl  = detectNL();   dbg('DOM', `NL: ${nl ? nl.tagName : 'none'}`);
    const cb  = detectCmpBtns(); dbg('DOM', `CmpBtns: ${cb ? cb.map(b=>(b.textContent||'').trim()).join(' ') : 'none'}`);
    dbg('DOM', `Inputs: ${[...document.querySelectorAll('input,textarea')].filter(outsideUI).length}`);
